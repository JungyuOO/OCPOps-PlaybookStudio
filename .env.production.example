# Copy to .env.production on the server and fill secrets/endpoints.
# Target deployment host: cywell-host / 192.168.119.23

# Public service URLs for operator reference.
# The nginx web container serves Studio at PLAYBOOKSTUDIO_PUBLIC_URL.
# The browser opens Terminal WebSocket directly on TERMINAL_PUBLIC_WS_URL.
PLAYBOOKSTUDIO_PUBLIC_URL=http://192.168.119.23:8080
TERMINAL_PUBLIC_WS_URL=ws://192.168.119.23:8770

# Image-based deployment. Override these with your company registry paths.
PLAYBOOKSTUDIO_APP_IMAGE=ghcr.io/jungyuoo/ocpops-playbookstudio-app:dev
PLAYBOOKSTUDIO_WEB_IMAGE=ghcr.io/jungyuoo/ocpops-playbookstudio-web:dev

# Public bind addresses
WEB_BIND=0.0.0.0:8080
TERMINAL_WS_BIND=0.0.0.0:8770
APP_HTTP_BIND=127.0.0.1:8765
POSTGRES_BIND=127.0.0.1:5432
QDRANT_HTTP_BIND=127.0.0.1:6335
QDRANT_GRPC_BIND=127.0.0.1:6336
QDRANT_VOLUME_NAME=ocp-rag-chatbot_qdrant_storage
POSTGRES_VOLUME_NAME=ocpops_playbookstudio_postgres_data

# Runtime artifacts
ARTIFACTS_DIR=/app/artifacts
OBJECT_STORAGE_ROOT=/app/storage

# PostgreSQL canonical runtime database
POSTGRES_DB=playbookstudio
POSTGRES_USER=playbookstudio
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://playbookstudio:change-me@postgres:5432/playbookstudio

# Embedding service
EMBEDDING_BASE_URL=http://tei.cywell.co.kr/v1
EMBEDDING_MODEL=dragonkue/bge-m3-ko
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=8

# Qdrant. The app container overrides QDRANT_URL to http://qdrant:6333.
QDRANT_COLLECTION=openshift_docs
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine
QDRANT_UPSERT_BATCH_SIZE=128
QDRANT_RECREATE_COLLECTION=false

# One-shot seed tuning. Defaults cover the current official corpus size.
OFFICIAL_CORPUS_INDEX_LIMIT=50000
OFFICIAL_CORPUS_REFRESH_LIMIT=50000
KMSC_COURSE_SOURCE_DIR=/app/corpus/sources/kmsc/parsed-preview/course_pbs

# Company LLM
LLM_ENDPOINT=http://cllm.cywell.co.kr/v1
LLM_MODEL=Qwen/Qwen3.5-9B

# Remote OpenShift SNO target for Terminal Session and Ops Console.
# Keep the token in server secrets or a private .env file, never in git.
OCP_API_BASE_URL=https://api.ocp.cywell.local:6443
OCP_API_TOKEN=replace-with-remote-sno-token
OCP_INSECURE_SKIP_TLS_VERIFY=true
OCP_DEFAULT_NAMESPACE=pbs-test
TERMINAL_ENABLED=true
TERMINAL_WS_PORT=8770
TERMINAL_SHELL=/app/scripts/terminal-entrypoint.sh
TERMINAL_SESSION_TTL_SECONDS=1800
TERMINAL_MAX_OUTPUT_BYTES=1048576

# Reranker
RERANKER_ENABLED=true
RERANKER_BASE_URL=http://tei.cywell.co.kr/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=12
RERANKER_BATCH_SIZE=8
RERANKER_DEVICE=auto
RERANKER_TIMEOUT_SECONDS=10
